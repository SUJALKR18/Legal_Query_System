# LexQueryia Backend - Environment Configuration Template
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!

# ============================================
# ChromaDB Vector Store Configuration
# ============================================
CHROMA_PERSIST_DIR=./chroma_db
COLLECTION_NAME=indian_laws

# ============================================
# LLM Provider Configuration
# Choose one or more providers (system will try in order)
# ============================================

# Groq - Free, Fast LLM API (RECOMMENDED)
# Get your key: https://console.groq.com/
# Free tier: 30 requests/minute
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Google AI Studio - Free tier available
# Get your key: https://makersuite.google.com/
GOOGLE_AI_API_KEY=your_google_ai_api_key_here
GOOGLE_AI_MODEL=gemini-2.0-flash

# Anthropic Claude - Paid API
# Get your key: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-20250514

# ============================================
# Server Configuration
# ============================================
HOST=0.0.0.0
PORT=8000

# ============================================
# Optional: Logging & Debugging
# ============================================
# LOG_LEVEL=INFO
# DEBUG=False
